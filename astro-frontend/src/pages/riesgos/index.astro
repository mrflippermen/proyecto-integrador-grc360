---
import Layout from '../../layouts/Layout.astro';
import { getRisks, chipClass, type Riesgo } from '../../lib/api';

let riesgos: Riesgo[] = [];
let error = '';
try {
  riesgos = await getRisks();
} catch (e) {
  error = 'No se pudo conectar con la API Flask (¿está corriendo en :5000?).';
}
---
<Layout title="Riesgos · CyberRisk 360" active="risks" crumb="<b>Identificación de riesgos</b> · Fase 2">
  <div class="page-head">
    <div>
      <div class="eyebrow">Fase 2 — Identificación y análisis de riesgos</div>
      <h1>Registro de riesgos</h1>
      <p>Cada riesgo combina un activo, una amenaza y una vulnerabilidad, valorado por Probabilidad × Impacto. Ordenado por riesgo residual.</p>
    </div>
    <a class="btn btn-primary" href="/riesgos/nuevo">+ Nuevo riesgo</a>
  </div>

  {error && <div class="flash flash-danger">{error}</div>}

  {riesgos.length > 0 && (
    <>
      <div class="card" style="padding:14px 16px; margin-bottom:14px">
        <div class="row" style="gap:10px">
          <input class="form-control" id="filtro" style="max-width:340px" placeholder="Buscar por código, activo, amenaza..." />
          <select class="form-control" id="filtroNivel" style="max-width:200px">
            <option value="">Todos los niveles (residual)</option>
            <option value="crítico">Crítico</option><option value="alto">Alto</option>
            <option value="medio">Medio</option><option value="bajo">Bajo</option>
          </select>
          <span class="dim" id="conteo" style="font-size:.82rem; margin-left:auto">{riesgos.length} riesgos</span>
        </div>
      </div>
      <div class="table-wrap">
        <table class="data" id="tabla">
          <thead><tr><th>Código</th><th>Activo</th><th>Amenaza / Vulnerabilidad</th><th>P×I</th><th>Inherente</th><th>Residual</th><th>Estado</th></tr></thead>
          <tbody>
            {riesgos.map((r) => (
              <tr
                onclick={`window.location='/riesgos/${r.id}'`}
                style="cursor:pointer"
                data-busca={`${r.codigo} ${r.activo.nombre} ${r.amenaza.nombre} ${r.vulnerabilidad.nombre}`.toLowerCase()}
                data-nivel={r.nivel_residual.nombre.toLowerCase()}
              >
                <td><span class="code">{r.codigo}</span></td>
                <td>{r.activo.nombre}</td>
                <td class="stack" style="gap:2px"><span>{r.amenaza.nombre}</span><span class="dim" style="font-size:.78rem">{r.vulnerabilidad.nombre}</span></td>
                <td class="mono muted">{r.probabilidad}×{r.impacto}</td>
                <td><span class={`chip chip-${chipClass(r.nivel_inherente.nombre)}`}>{r.puntaje_inherente} · {r.nivel_inherente.nombre}</span></td>
                <td class="row" style="gap:6px"><span class={`chip chip-${chipClass(r.nivel_residual.nombre)}`}>{r.puntaje_residual} · {r.nivel_residual.nombre}</span>{r.reduccion_pct > 0 && <span class="dim" style="font-size:.74rem">−{r.reduccion_pct}%</span>}</td>
                <td><span class="tag">{r.estado}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}
</Layout>

<script>
  const filtro = document.getElementById('filtro') as HTMLInputElement | null;
  const nivel = document.getElementById('filtroNivel') as HTMLSelectElement | null;
  const conteo = document.getElementById('conteo');
  const filas = Array.from(document.querySelectorAll<HTMLTableRowElement>('#tabla tbody tr'));

  function filtrar() {
    const q = (filtro?.value || '').toLowerCase();
    const n = nivel?.value || '';
    let visibles = 0;
    filas.forEach((tr) => {
      const okTexto = (tr.dataset.busca || '').includes(q);
      const okNivel = !n || tr.dataset.nivel === n;
      const show = okTexto && okNivel;
      tr.style.display = show ? '' : 'none';
      if (show) visibles++;
    });
    if (conteo) conteo.textContent = `${visibles} riesgos`;
  }
  filtro?.addEventListener('input', filtrar);
  nivel?.addEventListener('change', filtrar);
</script>
