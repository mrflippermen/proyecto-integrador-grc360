---
// Barra lateral con la navegación por las 6 fases de la metodología GRC-360.
interface Props { active?: string; }
const { active = '' } = Astro.props;

const fases = [
  { id: 'assets', n: '1', label: 'Valoración de activos', href: '/activos' },
  { id: 'risks', n: '2', label: 'Identificación de riesgos', href: '/riesgos' },
  { id: 'treatments', n: '3', label: 'Tratamiento (ISO 27002)', href: '/cumplimiento' },
  { id: 'residual', n: '4', label: 'Riesgo residual', href: '/riesgos' },
  { id: 'comm', n: '5', label: 'Comunicación y consulta', href: '/#comunicacion' },
  { id: 'dashboard', n: '6', label: 'Monitoreo y supervisión', href: '/' },
];
---
<aside class="sidebar">
  <a class="brand" href="/" style="text-decoration:none">
    <div class="brand-mark"><span></span></div>
    <div class="brand-name">CyberRisk 360<small>Gestión de Riesgos</small></div>
  </a>

  <a class={`nav-item ${active === 'dashboard' ? 'active' : ''}`} href="/">
    <svg class="ico ico-sm" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
    Panel de monitoreo
  </a>

  <div class="nav-label">Metodología GRC-360</div>
  {fases.map((f) => (
    <a class={`nav-item ${active === f.id ? 'active' : ''}`} href={f.href}>
      <span class="phase-num">{f.n}</span> {f.label}
    </a>
  ))}

  <div class="nav-label">Inteligencia y cumplimiento</div>
  <a class={`nav-item ${active === 'intel' ? 'active' : ''}`} href="/intel">
    <svg class="ico ico-sm" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
    Inteligencia de amenazas
  </a>
  <a class={`nav-item ${active === 'compliance' ? 'active' : ''}`} href="/cumplimiento">
    <svg class="ico ico-sm" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/><path d="M12 3l7 3v6c0 4-3 7-7 9-4-2-7-5-7-9V6z"/></svg>
    Cumplimiento
  </a>

  <div class="nav-label">Herramientas</div>
  <a class={`nav-item ${active === 'audit' ? 'active' : ''}`} href="/auditoria">
    <svg class="ico ico-sm" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg>
    Auditoría
  </a>
  <a class={`nav-item ${active === 'config' ? 'active' : ''}`} href="/configuracion">
    <svg class="ico ico-sm" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
    Configuración
  </a>
</aside>
